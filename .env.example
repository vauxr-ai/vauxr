# OpenClaw connection (required)
OPENCLAW_URL=wss://your-openclaw:18789
OPENCLAW_TOKEN=your-openclaw-gateway-token

# Shared device auth token (required)
DEVICE_TOKEN=your-device-shared-secret

# Wyoming service URLs (optional — defaults shown)
# WHISPER_URL=tcp://whisper:10300
# PIPER_URL=tcp://piper:10200

# WebSocket server port (optional — default 8765)
# WS_PORT=8765

# HTTP API server port (optional — default 8080)
# HTTP_PORT=8080

# Piper voice name (optional — default en_US-libritts_r-medium)
# PIPER_VOICE=en_US-libritts_r-medium

# Log level (optional — default info)
# LOG_LEVEL=info
