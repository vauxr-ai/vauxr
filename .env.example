# Shared device auth token (required)
DEVICE_TOKEN=your-device-shared-secret

# OpenClaw connection (optional — only needed for direct operator WS fallback mode.
# Recommended path is the vauxr-openclaw channel plugin installed in OpenClaw itself;
# see https://github.com/vauxr-ai/vauxr-openclaw)
# OPENCLAW_URL=wss://your-openclaw:18789
# OPENCLAW_TOKEN=your-openclaw-gateway-token

# Wyoming service URLs (optional — defaults shown)
# WHISPER_URL=tcp://whisper:10300
# PIPER_URL=tcp://piper:10200

# WebSocket server port (optional — default 8765)
# WS_PORT=8765

# HTTP API server port (optional — default 8080)
# HTTP_PORT=8080

# Piper voice name (optional — default en_US-libritts_r-medium)
# PIPER_VOICE=en_US-libritts_r-medium

# Streaming TTS — idle-pause threshold in milliseconds.
# When the assistant's delta stream goes silent for this long, the
# accumulated buffer is flushed to TTS as an early audio segment so
# replies start playing while the agent is still thinking or running
# tools. Lower = snappier but more fragmentation; higher = smoother
# prosody but more latency. (optional — default 400)
# STREAMING_TTS_IDLE_PAUSE_MS=400

# Log level (optional — default info)
# LOG_LEVEL=info
